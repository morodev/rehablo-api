# Server
NODE_ENV=development
PORT=3000

# Database (single Postgres instance, "public" schema for global/tenant data,
# one dynamic schema per tenant "rehablo_<tenantId>" for tenant-scoped business data)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rehablo
DB_SSL=false

# Auth
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_AUTH_USER=
EMAIL_AUTH_PASS=

# CORS
CORS_ORIGIN=*

